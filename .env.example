# text2gene2 configuration — copy to .env and fill in

# NCBI API key (get one free at https://www.ncbi.nlm.nih.gov/account/)
# Without this, NCBI rate limit is 3 req/sec; with it, 10 req/sec
NCBI_API_KEY=

# Google Programmable Search Engine
# Get from https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_WHITELIST_ID=009155410218757639293:nyh3tdzvfhc
GOOGLE_CSE_SCHEMA_ID=003914143621252222636:-mop04_esug

# Redis (defaults work for local dev)
REDIS_URL=redis://localhost:6379/0

# Cache TTLs (seconds)
CACHE_TTL_LVG=604800         # 7 days — transcripts are stable
CACHE_TTL_LITVAR2=86400      # 24 hours
CACHE_TTL_CLINVAR=86400      # 24 hours
CACHE_TTL_GOOGLE=604800      # 7 days — expensive, changes slowly
CACHE_TTL_EUROPEPMC=86400    # 24 hours

# VariantValidator
VARIANT_VALIDATOR_URL=https://rest.variantvalidator.org
VARIANT_VALIDATOR_GENOME_BUILD=GRCh38
# Rate limit: do not exceed 2/sec on the public API
VARIANT_VALIDATOR_RATE_LIMIT=1.5

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
